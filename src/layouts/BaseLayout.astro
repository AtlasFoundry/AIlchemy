---
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'hideaway. | a maker\'s hub',
  description = 'Practical resources for makers — guides, prompts, demos, and tools. Built by Laura.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,300;0,400;0,500;0,700;1,300;1,400;1,500&family=DM+Sans:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <Nav />
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  :root {
    /* hideaway. palette */
    --frosted:  #F7F6F1;
    --navy:     #1A2744;
    --sage:     #9CAF88;
    --yellow:   #E8F547;
    --stone:    #D4CFC4;

    /* Functional aliases */
    --bg:         var(--frosted);
    --text:       var(--navy);
    --text-light: #5E6B82;
    --border:     rgba(26, 39, 68, 0.1);

    /* Stage colours */
    --stage-download: var(--sage);
    --stage-idea:     var(--stone);
    --stage-creation: var(--navy);
  }

  *,
  *::before,
  *::after {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
  }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--bg);
    color: var(--text);
    overflow-x: hidden;
  }

  h1, h2, h3, h4, h5, h6,
  [style*="Fraunces"], .nav-logo {
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  /* Shared button styles */
  .btn-primary {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    background: var(--navy);
    color: var(--frosted);
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.25s;
    border: 2px solid var(--navy);
    cursor: pointer;
  }

  .btn-primary:hover {
    background: #0f1a30;
    border-color: #0f1a30;
  }

  .btn-secondary {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    background: transparent;
    color: var(--navy);
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    border: 2px solid var(--navy);
    transition: all 0.25s;
  }

  .btn-secondary:hover {
    background: var(--navy);
    color: var(--frosted);
  }

  .btn-yellow {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    background: #E8F547;
    color: var(--navy);
    text-decoration: none;
    border-radius: 6px;
    font-weight: 700;
    font-size: 0.9rem;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.25s;
    border: 2px solid #E8F547;
    cursor: pointer;
  }

  .btn-yellow:hover {
    background: #d4e03a;
    border-color: #d4e03a;
  }

  .btn-sage {
    display: inline-block;
    padding: 0.85rem 1.8rem;
    background: var(--sage);
    color: var(--navy);
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    font-size: 0.9rem;
    font-family: 'DM Sans', sans-serif;
    transition: all 0.25s;
    border: 2px solid var(--sage);
    cursor: pointer;
  }

  .btn-sage:hover {
    background: #8a9e77;
    border-color: #8a9e77;
  }
</style>
