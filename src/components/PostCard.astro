---
interface Props {
  title: string;
  stage: 'download' | 'idea' | 'creation';
  format: 'guide' | 'prompt' | 'demo' | 'reflection' | 'pack';
  summary: string;
  date: Date;
  readTime: string;
  slug: string;
  dark?: boolean;
}

const { title, stage, format, summary, date, readTime, slug, dark = false } = Astro.props;

const stageLabels: Record<string, string> = {
  download: 'Download.',
  idea: 'Idea.',
  creation: 'Creation.',
};

const formatLabels: Record<string, string> = {
  guide: 'Guide',
  prompt: 'Prompt',
  demo: 'Demo',
  reflection: 'Reflection',
  pack: 'Pack',
};
---

<a href={`/posts/${slug}`} class:list={['post-card', { dark }, stage]}>
  <div class="post-tags">
    <span class:list={['tag-stage', stage]}>{stageLabels[stage]}</span>
    <span class="tag-format">{formatLabels[format]}</span>
    <span class="tag-time">{readTime}</span>
  </div>
  <h3>{title}</h3>
  <p>{summary}</p>
</a>

<style>
  .post-card {
    display: block;
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 1.6rem;
    text-decoration: none;
    transition: all 0.25s;
  }

  .post-card:hover {
    box-shadow: 0 6px 24px rgba(26, 39, 68, 0.08);
    border-color: var(--stone);
  }

  /* Dark variant (homepage latest) */
  .post-card.dark {
    background: rgba(255, 255, 255, 0.06);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .post-card.dark:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
    box-shadow: none;
  }

  .post-tags {
    display: flex;
    gap: 0.4rem;
    align-items: center;
    flex-wrap: wrap;
    margin-bottom: 0.9rem;
  }

  .tag-stage {
    font-size: 0.7rem;
    font-weight: 600;
    font-family: 'Fraunces', serif;
    padding: 0.2rem 0.55rem;
    border-radius: 4px;
  }

  .tag-stage.download {
    background: rgba(156, 175, 136, 0.18);
    color: #4d6e3c;
  }

  .tag-stage.idea {
    background: rgba(212, 207, 196, 0.5);
    color: #6b6254;
  }

  .tag-stage.creation {
    background: rgba(26, 39, 68, 0.1);
    color: var(--navy);
  }

  .tag-format {
    font-size: 0.7rem;
    font-weight: 500;
    color: var(--text-light);
    padding: 0.2rem 0.55rem;
    background: rgba(26, 39, 68, 0.05);
    border-radius: 4px;
  }

  .tag-time {
    font-size: 0.7rem;
    color: var(--text-light);
    margin-left: auto;
  }

  /* Dark variant tag overrides */
  .post-card.dark .tag-stage.download {
    background: rgba(156, 175, 136, 0.25);
    color: #a8c492;
  }

  .post-card.dark .tag-stage.idea {
    background: rgba(212, 207, 196, 0.2);
    color: #c5bfb5;
  }

  .post-card.dark .tag-stage.creation {
    background: rgba(255, 255, 255, 0.12);
    color: rgba(255, 255, 255, 0.7);
  }

  .post-card.dark .tag-format {
    background: rgba(255, 255, 255, 0.08);
    color: rgba(255, 255, 255, 0.5);
  }

  .post-card.dark .tag-time {
    color: rgba(255, 255, 255, 0.35);
  }

  .post-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.08rem;
    font-weight: 500;
    margin-bottom: 0.5rem;
    color: var(--navy);
    line-height: 1.35;
  }

  .post-card.dark h3 {
    color: white;
  }

  .post-card p {
    font-size: 0.85rem;
    color: var(--text-light);
    line-height: 1.6;
  }

  .post-card.dark p {
    color: rgba(255, 255, 255, 0.5);
  }
</style>
