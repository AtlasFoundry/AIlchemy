---

<footer>
  <div class="footer-inner">

    <div class="footer-logo"><span class="logo-h">h</span><span class="logo-idea">idea</span><span class="logo-way">way.</span></div>

    <div class="footer-nav">
      <div class="footer-col">
        <span class="footer-col-label">Hub</span>
        <a href="/library">Library</a>
        <a href="/prompt-lab">Prompt Lab</a>
        <a href="/ideas">Ideas</a>
        <a href="/subscribe">Subscribe</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Made</span>
        <a href="/bothy">Bothy.</a>
        <a href="/atlas">Atlas.</a>
      </div>
    </div>

  </div>

  <div class="footer-base">
    <span>© hideaway. 2025</span>
  </div>
</footer>

<style>
  footer {
    border-top: 1px solid var(--border);
    background: var(--frosted);
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 3rem 2.5rem;
    display: flex;
    justify-content: flex-start;
    align-items: flex-start;
    gap: 4rem;
  }

  .footer-logo {
    font-family: 'Fraunces', serif;
    font-size: 1.7rem;
    font-weight: 500;
    display: inline-block;
    background: var(--navy);
    padding: 0.3rem 0.8rem 0.35rem;
    border-radius: 6px;
    font-optical-sizing: none;
    font-feature-settings: normal;
    flex-shrink: 0;
  }

  .logo-h    { color: var(--sage); }
  .logo-idea { color: #E8F547; }
  .logo-way  { color: var(--sage); }

  .footer-nav {
    display: flex;
    gap: 3rem;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .footer-col-label {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--text-light);
    margin-bottom: 0.3rem;
  }

  .footer-col a {
    font-size: 0.88rem;
    color: var(--text-light);
    text-decoration: none;
    transition: color 0.25s;
  }

  .footer-col a:hover {
    color: var(--navy);
  }

  .footer-base {
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.2rem 3rem;
    border-top: 1px solid var(--border);
  }

  .footer-base span {
    font-size: 0.8rem;
    color: var(--text-light);
  }

  @media (max-width: 768px) {
    .footer-inner {
      flex-direction: column;
      gap: 2rem;
      padding: 2.5rem 1.5rem 2rem;
    }

    .footer-base {
      padding: 1.2rem 1.5rem;
    }
  }
</style>
