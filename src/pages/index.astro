---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('posts');
const latestPosts = allPosts
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3);
---

<BaseLayout
  title="hideaway. | a maker's hub"
  description="Practical resources for makers — guides, prompts, demos, and tools. Built by Laura."
>

  <!-- INTRO -->
  <section class="intro">
    <div class="intro-inner">
      <div class="intro-label">A maker's hub</div>
      <h1>From first spark<br />to finished thing.</h1>
      <p>
        hideaway. is a hub for people bringing ideas to life. Practical resources — guides,
        prompts, demos, and tools — organised around how making actually works.
      </p>
      <div class="intro-cta">
        <a href="/library" class="btn-yellow">Explore the library</a>
        <a href="/subscribe" class="btn-secondary">Stay in the loop</a>
      </div>
    </div>
  </section>

  <!-- THE THREE STAGES -->
  <section class="stages" id="stages">
    <div class="stages-inner">
      <div class="stages-grid">

        <a href="/library?stage=download" class="stage-tile">
          <div class="tile-header">
            <span class="tile-number">01</span>
            <span class="tile-name">Download.</span>
          </div>
          <div class="tile-body">
            <h3>Capture what you notice.</h3>
            <p>Before an idea has shape, there's a signal worth keeping. Resources here help you slow down and not lose what matters.</p>
            <span class="tile-link">Resources →</span>
          </div>
        </a>

        <a href="/library?stage=idea" class="stage-tile">
          <div class="tile-header">
            <span class="tile-number">02</span>
            <span class="tile-name">Idea.</span>
          </div>
          <div class="tile-body">
            <h3>Shape what you've got.</h3>
            <p>An observation becomes an idea when you test it. Resources here help you move from vague possibility to something worth building.</p>
            <span class="tile-link">Resources →</span>
          </div>
        </a>

        <a href="/library?stage=creation" class="stage-tile">
          <div class="tile-header">
            <span class="tile-number">03</span>
            <span class="tile-name">Creation.</span>
          </div>
          <div class="tile-body">
            <h3>Build the actual thing.</h3>
            <p>Guides, demos, and tools for the build phase — practical, specific, no filler. Just what you need to move forward.</p>
            <span class="tile-link">Resources →</span>
          </div>
        </a>

      </div>
    </div>
  </section>

  <!-- LATEST FROM THE LIBRARY -->
  <section class="latest" id="latest">
    <div class="latest-inner">
      <div class="latest-header">
        <h2>Latest from the library</h2>
        <a href="/library" class="see-all">See all →</a>
      </div>
      <div class="latest-grid">
        {
          latestPosts.map((post) => (
            <PostCard
              title={post.data.title}
              stage={post.data.stage}
              format={post.data.format}
              summary={post.data.summary}
              date={post.data.date}
              readTime={post.data.readTime}
              slug={post.id}
              dark={false}
            />
          ))
        }
      </div>
    </div>
  </section>

  <!-- LOOK WHAT I MADE -->
  <section class="made" id="made">
    <div class="made-inner">
      <div class="made-header">
        <div class="section-label">Look what I made.</div>
        <h2>Ideas that became real things.</h2>
        <p>
          Each one started as a problem someone shared with me. Each one is built to make
          something easier for someone who needs it.
        </p>
      </div>

      <div class="made-grid">
        <div class="made-card">
          <div class="made-card-tag">Financial guidance</div>
          <h3>Bothy.</h3>
          <p>
            Plain-language guidance for adults navigating complex financial forms. No jargon,
            no judgment — just clear explanations for real decisions. Currently focused on
            pension transfers.
          </p>
          <a href="/bothy" class="made-link">Read the story →</a>
        </div>

        <div class="made-card">
          <div class="made-card-tag">Evidence synthesis</div>
          <h3>Atlas.</h3>
          <p>
            Atlas turns scattered evidence into a usable map. Feed it reports, documents, and
            data — it finds the patterns and surfaces what matters, so you stop building
            solutions to problems you can't quite see.
          </p>
          <a href="/atlas" class="made-link">Read the story →</a>
        </div>
      </div>
    </div>
  </section>

  <!-- IDEAS -->
  <section class="ideas-tease" id="ideas">
    <div class="ideas-tease-inner">
      <div class="ideas-tease-text">
        <div class="section-label">Ideas.</div>
        <h2>What would actually help you?</h2>
        <p>
          The resources here are built around real problems. If there's something you're stuck on,
          a format you'd find useful, or a question that keeps coming back — send it in. The best
          guides start with someone asking the right thing.
        </p>
        <a href="/ideas" class="btn-primary">Submit an idea</a>
      </div>
      <div class="ideas-tease-aside">
        <div class="ideas-example">
          <span class="ideas-example-label">Recent idea request</span>
          <p>"A prompt for turning messy meeting notes into a clear action list."</p>
        </div>
        <div class="ideas-example">
          <span class="ideas-example-label">In the queue</span>
          <p>"A guide to building a simple knowledge base with Claude Projects."</p>
        </div>
      </div>
    </div>
  </section>

  <!-- SUBSCRIBE -->
  <section class="subscribe-strip">
    <div class="subscribe-strip-inner">
      <div class="subscribe-strip-text">
        <h2>Worth staying for.</h2>
        <p>New resources when they're ready — not on a schedule. No noise.</p>
      </div>
      <form class="subscribe-strip-form" action="https://app.convertkit.com/forms/REPLACE_ID/subscriptions" method="post" target="_blank">
        <input type="email" name="email_address" placeholder="your@email.com" required />
        <button type="submit" class="btn-primary">Subscribe</button>
      </form>
    </div>
  </section>

</BaseLayout>

<style>
  /* ── INTRO ── */
  .intro {
    min-height: 90vh;
    display: flex;
    align-items: center;
    padding: 9rem 3rem 5rem;
  }

  .intro-inner {
    max-width: 680px;
  }

  .intro-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sage);
    margin-bottom: 1.5rem;
  }

  .intro h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.8rem, 5.5vw, 4.4rem);
    font-weight: 400;
    line-height: 1.12;
    color: var(--navy);
    margin-bottom: 1.5rem;
    letter-spacing: -0.02em;
  }

  .intro p {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text-light);
    max-width: 520px;
    margin-bottom: 2.5rem;
  }

  .intro-cta {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  /* ── STAGES ── */
  .stages {
    padding: 4rem 3rem 5rem;
  }

  .stages-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .stages-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.2rem;
    align-items: stretch;
  }

  .stage-tile {
    display: flex;
    flex-direction: column;
    border-radius: 12px;
    border: 1px solid var(--stone);
    text-decoration: none;
    overflow: hidden;
    background: white;
    transition: border-color 0.25s, background 0.25s, transform 0.25s;
  }

  .stage-tile:hover {
    border-color: var(--sage);
    background: rgba(156, 175, 136, 0.05);
    transform: translateY(-3px);
  }

  .tile-header {
    background: var(--navy);
    padding: 1.4rem 1.8rem 1.3rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .tile-number {
    font-family: 'Fraunces', serif;
    font-style: italic;
    font-size: 0.82rem;
    color: var(--sage);
    font-optical-sizing: none;
  }

  .tile-name {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 400;
    color: #E8F547;
    line-height: 1;
    letter-spacing: -0.01em;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .tile-body {
    padding: 1.6rem 1.8rem 2rem;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .tile-body h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 0.65rem;
    line-height: 1.3;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .tile-body p {
    font-size: 0.88rem;
    color: var(--text-light);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.4rem;
  }

  .tile-link {
    font-size: 0.82rem;
    font-weight: 600;
    color: var(--sage);
    transition: color 0.25s;
  }

  .stage-tile:hover .tile-link {
    color: var(--navy);
  }

  /* ── LATEST ── */
  .latest {
    padding: 5rem 3rem;
    background: var(--navy);
  }

  .latest-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .latest-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    margin-bottom: 2.5rem;
  }

  .latest-header h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.6rem;
    font-weight: 400;
    color: white;
  }

  .see-all {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.5);
    text-decoration: none;
    transition: color 0.25s;
  }

  .see-all:hover {
    color: white;
  }

  .latest-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.2rem;
  }

  /* ── MADE ── */
  .made {
    padding: 6rem 3rem;
  }

  .made-inner {
    max-width: 1100px;
    margin: 0 auto;
  }

  .section-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sage);
    margin-bottom: 0.9rem;
  }

  .made-header {
    max-width: 560px;
    margin-bottom: 3rem;
  }

  .made-header h2 {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 0.7rem;
  }

  .made-header p {
    font-size: 1rem;
    color: var(--text-light);
    line-height: 1.7;
  }

  .made-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }

  .made-card {
    background: var(--navy);
    border: 1px solid var(--navy);
    border-radius: 10px;
    padding: 2rem;
    transition: all 0.25s;
  }

  .made-card:hover {
    background: #0f1a30;
    border-color: #0f1a30;
  }

  .made-card-tag {
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--sage);
    margin-bottom: 0.7rem;
  }

  .made-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 400;
    color: #E8F547;
    margin-bottom: 0.8rem;
    letter-spacing: -0.01em;
  }

  .made-card p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.7;
    margin-bottom: 1.5rem;
  }

  .made-link {
    font-size: 0.85rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.6);
    text-decoration: none;
    transition: color 0.2s;
  }

  .made-link:hover {
    color: white;
  }

  /* ── IDEAS TEASE ── */
  .ideas-tease {
    padding: 5rem 3rem;
    background: var(--stone);
  }

  .ideas-tease-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 5rem;
    align-items: center;
  }

  .ideas-tease-text .section-label {
    color: #6b6254;
  }

  .ideas-tease-text h2 {
    font-family: 'Fraunces', serif;
    font-size: 2rem;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 1rem;
    line-height: 1.2;
  }

  .ideas-tease-text p {
    font-size: 0.95rem;
    color: #6b6254;
    line-height: 1.75;
    margin-bottom: 2rem;
  }

  .ideas-tease-aside {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .ideas-example {
    background: rgba(247, 246, 241, 0.7);
    border: 1px solid rgba(26, 39, 68, 0.1);
    border-radius: 8px;
    padding: 1.2rem 1.4rem;
  }

  .ideas-example-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #8a7f70;
    margin-bottom: 0.5rem;
  }

  .ideas-example p {
    font-size: 0.88rem;
    color: var(--navy);
    font-style: italic;
    line-height: 1.5;
    margin: 0;
  }

  /* ── SUBSCRIBE STRIP ── */
  .subscribe-strip {
    padding: 4rem 3rem;
    border-top: 1px solid var(--border);
  }

  .subscribe-strip-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 3rem;
    flex-wrap: wrap;
  }

  .subscribe-strip-text h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 0.3rem;
  }

  .subscribe-strip-text p {
    font-size: 0.9rem;
    color: var(--text-light);
  }

  .subscribe-strip-form {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .subscribe-strip-form input[type="email"] {
    padding: 0.8rem 1.2rem;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--navy);
    background: white;
    min-width: 220px;
    transition: border-color 0.25s;
    outline: none;
  }

  .subscribe-strip-form input[type="email"]:focus {
    border-color: var(--navy);
  }

  .subscribe-strip-form input[type="email"]::placeholder {
    color: var(--text-light);
  }

  /* ── RESPONSIVE ── */
  @media (max-width: 900px) {
    .intro {
      padding: 8rem 1.5rem 4rem;
    }

    .stages {
      padding: 3rem 1.5rem 4rem;
    }

    .stages-grid {
      grid-template-columns: 1fr;
    }

    .latest {
      padding: 4rem 1.5rem;
    }

    .made {
      padding: 4rem 1.5rem;
    }

    .ideas-tease {
      padding: 4rem 1.5rem;
    }

    .ideas-tease-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .subscribe-strip {
      padding: 3rem 1.5rem;
    }

    .subscribe-strip-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.5rem;
    }
  }

  @media (max-width: 600px) {
    .intro h1 {
      font-size: 2.4rem;
    }

    .latest-grid {
      grid-template-columns: 1fr;
    }

    .made-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
