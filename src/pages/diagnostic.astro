---
import BaseLayout from '../layouts/BaseLayout.astro';
import rawQuestions from '../content/memo/questions.json';
import rawSubdomains from '../content/memo/subdomains.json';
import rawStages from '../content/memo/stages.json';
import rawPatterns from '../content/memo/patterns.json';
---

<BaseLayout
  title="Makers Memo — hideaway."
  description="A structured diagnostic across Download, Idea, and Creation. Returns your Makers Memo: your pattern, your strongest moves, the gaps that matter, and where to focus next."
>

<!-- ─── INTRO ─────────────────────────────────────────────────── -->
<section id="view-intro" class="diag-view">
  <div class="intro-hero">
    <div class="intro-hero-inner">
      <div class="diag-tag">Diagnostic</div>
      <h1>Makers<span class="accent"> Memo.</span></h1>
      <p class="intro-sub">A structured read of how you currently work across three stages — Download, Idea, and Creation.</p>
      <p class="intro-sub">Not a personality quiz. The output is a Memo: your pattern, your strongest moves, the gaps that matter, and where to focus next.</p>
      <div class="intro-meta">
        <span>36 questions</span>
        <span>·</span>
        <span>~10 minutes</span>
        <span>·</span>
        <span>Output: your Makers Memo</span>
      </div>
      <button class="btn-yellow btn-begin" id="btn-begin">Begin the diagnostic →</button>
    </div>
  </div>
  <div class="intro-stages">
    <div class="intro-stages-inner">
      <div class="stage-card">
        <span class="stage-num">01</span>
        <h3>Download.</h3>
        <p>Capturing, noticing, organising, and selecting raw material.</p>
      </div>
      <div class="stage-card">
        <span class="stage-num">02</span>
        <h3>Idea.</h3>
        <p>Shaping, testing, clarifying, and deciding what's worth building.</p>
      </div>
      <div class="stage-card">
        <span class="stage-num">03</span>
        <h3>Creation.</h3>
        <p>Building, finishing, releasing, and iterating on what you've made.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── INTERSTITIAL ──────────────────────────────────────────── -->
<section id="view-interstitial" class="diag-view" style="display:none;">
  <div class="interstitial-wrapper">
    <div class="interstitial-inner">
      <span class="interstitial-badge" id="int-badge"></span>
      <h2 class="interstitial-heading" id="int-heading"></h2>
      <p class="interstitial-body" id="int-body"></p>
      <button class="btn-yellow" id="btn-continue">Continue →</button>
    </div>
  </div>
</section>

<!-- ─── QUESTIONS ─────────────────────────────────────────────── -->
<section id="view-questions" class="diag-view" style="display:none;">
  <div class="q-chrome">
    <div class="q-stage-segments" role="progressbar" aria-label="Diagnostic progress">
      <div class="q-seg" id="q-seg-download">
        <div class="q-seg-track"><div class="q-seg-fill" id="q-seg-fill-download"></div></div>
      </div>
      <div class="q-seg" id="q-seg-idea">
        <div class="q-seg-track"><div class="q-seg-fill" id="q-seg-fill-idea"></div></div>
      </div>
      <div class="q-seg" id="q-seg-creation">
        <div class="q-seg-track"><div class="q-seg-fill" id="q-seg-fill-creation"></div></div>
      </div>
    </div>
  </div>

  <div class="q-body">
    <div class="q-content">
      <div class="q-meta">
        <div class="q-meta-left">
          <span class="q-subdomain" id="q-subdomain"></span>
          <span class="q-subdomain-desc" id="q-subdomain-desc"></span>
        </div>
        <span class="q-counter" id="q-counter"></span>
      </div>
      <p class="q-text" id="q-text"></p>
      <div class="q-options" id="q-options"></div>
      <div class="q-nav">
        <button class="btn-ghost" id="btn-back">← Back</button>
        <button class="btn-next" id="btn-next" disabled>Next →</button>
      </div>
    </div>
  </div>
</section>

<!-- ─── MAKERS MEMO ────────────────────────────────────────────── -->
<section id="view-memo" class="diag-view" style="display:none;">
  <div class="memo-wrapper">
    <div class="memo" id="memo">

      <div class="memo-header">
        <div class="memo-logo"><span class="logo-h">h</span><span class="logo-idea">idea</span><span class="logo-way">way.</span></div>
        <div class="memo-title-block">
          <h1>Makers Memo</h1>
          <p class="memo-date" id="memo-date"></p>
        </div>
      </div>

      <div class="memo-overview">
        <div class="memo-overview-cell">
          <span class="memo-label">Overall</span>
          <span class="memo-score-value" id="memo-overall-score"></span>
        </div>
        <div class="memo-overview-cell">
          <span class="memo-label">Band</span>
          <span class="memo-band-value" id="memo-band"></span>
        </div>
        <div class="memo-overview-cell">
          <span class="memo-label">Pattern</span>
          <span class="memo-pattern-value" id="memo-pattern-label"></span>
        </div>
      </div>

      <div class="memo-section memo-pattern-section">
        <h2>What your pattern means</h2>
        <p class="memo-pattern-meaning" id="memo-pattern-meaning"></p>
        <div class="memo-next-move">
          <span class="memo-next-label">Best next move</span>
          <p class="memo-next-text" id="memo-pattern-next"></p>
        </div>
      </div>

      <div class="memo-section memo-stages-section">
        <h2>Stage scores</h2>
        <div class="memo-stage-grid" id="memo-stage-grid"></div>
      </div>

      <div class="memo-section memo-subdomains-section">
        <h2>Subdomain breakdown</h2>
        <div class="memo-sub-table" id="memo-sub-table"></div>
      </div>

      <div class="memo-section memo-resources-section">
        <h2>Where to go next in hideaway.</h2>
        <p class="memo-resources-intro">Prioritised by the items where you scored lowest, weighted by question importance.</p>
        <div class="memo-resource-list" id="memo-resource-list"></div>
      </div>

      <div class="memo-section memo-retake">
        <p>Retake this in 3–6 months. Compare subdomain scores rather than the overall number — real change shows up at subdomain level first.</p>
      </div>

    </div>

    <div class="memo-actions">
      <button class="btn-yellow" onclick="window.print()">Print / Save as PDF</button>
      <button class="btn-ghost" id="btn-retake-memo">Start again</button>
    </div>
  </div>
</section>

</BaseLayout>

<style is:global>
  /* ── base ─────────────────────────────────── */
  .diag-view { min-height: 100vh; }

  .diag-tag {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.6);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  /* ── intro ────────────────────────────────── */
  .intro-hero {
    background: var(--navy);
    padding: 9rem 3rem 5rem;
  }

  .intro-hero-inner { max-width: 720px; margin: 0 auto; }

  .intro-hero h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 500;
    color: white;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .accent { color: #E8F547; }

  .intro-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-width: 580px;
    margin: 0 0 0.8rem;
  }

  .intro-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin: 1.5rem 0 2.2rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
    flex-wrap: wrap;
  }

  .btn-begin {
    font-size: 1rem;
    padding: 0.85rem 2rem;
    border: none;
    cursor: pointer;
  }

  .intro-stages {
    background: var(--frosted);
    padding: 4rem 3rem;
  }

  .intro-stages-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .stage-card {
    padding: 2rem 1.8rem;
    background: white;
    border: 1px solid var(--stone);
    border-radius: 10px;
  }

  .stage-num {
    display: block;
    font-family: 'Fraunces', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--sage);
    margin-bottom: 0.6rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .stage-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--navy);
    margin: 0 0 0.6rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .stage-card p {
    font-size: 0.9rem;
    color: rgba(26,39,68,0.6);
    line-height: 1.6;
    margin: 0;
  }

  /* ── interstitial ─────────────────────────── */
  .interstitial-wrapper {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      radial-gradient(ellipse at 20% 10%, rgba(156,175,136,0.14) 0%, transparent 55%),
      radial-gradient(ellipse at 85% 90%, rgba(212,207,196,0.22) 0%, transparent 60%),
      linear-gradient(180deg, rgba(156,175,136,0.06) 0%, rgba(212,207,196,0.10) 100%);
    padding: 7rem 2rem 5rem;
  }

  .interstitial-inner {
    max-width: 540px;
    text-align: center;
    position: relative;
  }

  .interstitial-inner::before {
    content: '';
    display: block;
    width: 28px;
    height: 2px;
    background: var(--sage);
    margin: 0 auto 1.4rem;
    opacity: 0.75;
  }

  .interstitial-badge {
    display: inline-block;
    background: transparent;
    color: var(--sage);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    padding: 0;
    margin-bottom: 1.4rem;
  }

  .interstitial-heading {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 500;
    color: var(--navy);
    margin: 0 0 1.3rem;
    line-height: 1.15;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .interstitial-body {
    font-size: 1.05rem;
    color: rgba(26,39,68,0.62);
    line-height: 1.7;
    margin: 0 0 2.4rem;
  }

  /* ── questions ────────────────────────────── */
  .q-chrome {
    background: var(--navy);
    padding: 3.8rem 3rem 1.3rem;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .q-stage-segments {
    display: flex;
    gap: 0.55rem;
    max-width: 760px;
    margin: 0 auto;
  }

  .q-seg {
    flex: 1;
    display: block;
  }

  .q-seg-track {
    height: 3px;
    background: rgba(255,255,255,0.09);
    border-radius: 2px;
    overflow: hidden;
  }

  .q-seg-fill {
    height: 100%;
    background: rgba(255,255,255,0.25);
    border-radius: 2px;
    transition: width 0.4s ease, background 0.25s ease;
    width: 0%;
  }

  .q-seg.seg-active .q-seg-fill { background: var(--sage); }
  .q-seg.seg-done   .q-seg-fill { background: var(--sage); }

  .q-body {
    position: relative;
    min-height: calc(100vh - 130px);
    padding: 4rem 3rem 5rem;
    display: flex;
    justify-content: center;
    background:
      radial-gradient(ellipse 55% 60% at 12% 18%, rgba(156,175,136,0.09) 0%, transparent 70%),
      radial-gradient(ellipse 50% 55% at 90% 82%, rgba(212,207,196,0.18) 0%, transparent 72%),
      linear-gradient(180deg, rgba(247,246,241,1) 0%, rgba(247,246,241,0.85) 100%);
  }

  .q-body::before {
    content: '';
    position: absolute;
    top: 4.5rem;
    left: 50%;
    transform: translateX(-50%);
    width: min(720px, calc(100% - 6rem));
    height: 1px;
    background: linear-gradient(90deg, transparent 0%, rgba(156,175,136,0.22) 50%, transparent 100%);
    pointer-events: none;
  }

  .q-content {
    width: 100%;
    max-width: 720px;
  }

  .q-meta {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .q-meta-left {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .q-subdomain {
    font-size: 0.74rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: var(--sage);
  }

  .q-subdomain-desc {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 400;
    color: rgba(26,39,68,0.68);
    line-height: 1.45;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .q-counter {
    font-size: 0.78rem;
    color: rgba(26,39,68,0.4);
    flex-shrink: 0;
    padding-top: 0.2rem;
  }

  .q-text {
    font-family: 'Fraunces', serif;
    font-size: clamp(1.35rem, 3vw, 1.85rem);
    font-weight: 400;
    color: var(--navy);
    line-height: 1.4;
    margin: 0 0 2.2rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .q-options {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    margin-bottom: 2.8rem;
  }

  .q-option {
    display: block;
    position: relative;
    padding: 1.25rem 1.5rem 1.25rem 1.5rem;
    background: white;
    border: 1.5px solid var(--stone);
    border-left: 4px solid transparent;
    border-radius: 10px;
    cursor: pointer;
    transition: border-color 0.18s ease, background 0.18s ease, transform 0.14s ease, box-shadow 0.18s ease;
    user-select: none;
  }

  .q-option:hover {
    border-color: rgba(156,175,136,0.55);
    border-left-color: var(--sage);
    background: rgba(156,175,136,0.05);
    transform: translateX(2px);
  }

  .q-option.selected {
    border-color: rgba(232,245,71,0.55);
    border-left-color: #E8F547;
    background: rgba(232,245,71,0.09);
    box-shadow: 0 1px 0 rgba(26,39,68,0.04);
  }

  .q-option input[type="radio"] {
    position: absolute;
    opacity: 0;
    pointer-events: none;
    width: 0;
    height: 0;
  }

  .q-option-label {
    display: block;
    font-size: 1.02rem;
    color: var(--navy);
    line-height: 1.55;
    cursor: pointer;
  }

  .q-nav {
    display: flex;
    justify-content: flex-end;
    gap: 0.8rem;
    align-items: center;
  }

  /* ── shared buttons ───────────────────────── */
  .btn-yellow {
    display: inline-block;
    background: #E8F547;
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 0.75rem 1.7rem;
    border-radius: 7px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-yellow:hover { background: #d4e03a; }

  .btn-ghost {
    background: transparent;
    border: 1.5px solid var(--stone);
    color: rgba(26,39,68,0.55);
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    padding: 0.7rem 1.3rem;
    border-radius: 7px;
    cursor: pointer;
    transition: border-color 0.2s ease, color 0.2s ease, background 0.2s ease;
  }

  .btn-ghost:hover {
    border-color: rgba(156,175,136,0.6);
    color: var(--navy);
    background: rgba(156,175,136,0.05);
  }

  .btn-next {
    background: rgba(26,39,68,0.05);
    color: rgba(26,39,68,0.4);
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.92rem;
    padding: 0.75rem 1.7rem;
    border-radius: 7px;
    border: 1.5px solid rgba(26,39,68,0.08);
    cursor: not-allowed;
    transform: translateY(0);
    transition: background 0.22s ease, color 0.22s ease, border-color 0.22s ease, transform 0.22s ease, box-shadow 0.22s ease;
  }

  .btn-next:not([disabled]) {
    background: #E8F547;
    color: var(--navy);
    border-color: #E8F547;
    font-weight: 700;
    cursor: pointer;
    transform: translateY(-1px);
    box-shadow: 0 2px 0 rgba(26,39,68,0.08);
  }

  .btn-next:not([disabled]):hover {
    background: #d4e03a;
    border-color: #d4e03a;
  }

  /* ── memo (output) ────────────────────────── */
  .memo-wrapper {
    background: var(--frosted);
    padding: 7rem 2.5rem 5rem;
  }

  .memo {
    max-width: 860px;
    margin: 0 auto 2rem;
    background: white;
    border: 1px solid var(--stone);
    border-radius: 12px;
    overflow: hidden;
  }

  .memo-header {
    background: var(--navy);
    padding: 2rem 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .memo-logo {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 500;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .logo-h    { color: var(--sage); }
  .logo-idea { color: #E8F547; }
  .logo-way  { color: var(--sage); }

  .memo-title-block { text-align: right; }

  .memo-title-block h1 {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: white;
    margin: 0 0 0.2rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .memo-date {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.45);
    margin: 0;
  }

  .memo-overview {
    display: grid;
    grid-template-columns: auto 1fr 1fr;
    gap: 2rem;
    padding: 2rem 2.5rem;
    background: rgba(26,39,68,0.03);
    border-bottom: 1px solid var(--stone);
    align-items: start;
  }

  .memo-overview-cell {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .memo-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: rgba(26,39,68,0.4);
  }

  .memo-score-value {
    font-family: 'Fraunces', serif;
    font-size: 2.4rem;
    font-weight: 400;
    color: var(--navy);
    line-height: 1;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .memo-band-value,
  .memo-pattern-value {
    font-family: 'Fraunces', serif;
    font-size: 1.25rem;
    font-weight: 500;
    color: var(--navy);
    line-height: 1.2;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .memo-section {
    padding: 2rem 2.5rem;
    border-bottom: 1px solid var(--stone);
  }

  .memo-section:last-child { border-bottom: none; }

  .memo-section h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--navy);
    margin: 0 0 1rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .memo-pattern-meaning {
    font-size: 0.96rem;
    color: rgba(26,39,68,0.75);
    line-height: 1.65;
    margin: 0 0 1.2rem;
  }

  .memo-next-move {
    background: rgba(156,175,136,0.10);
    border-left: 3px solid var(--sage);
    padding: 1rem 1.2rem;
    border-radius: 4px;
  }

  .memo-next-label {
    display: block;
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sage);
    margin-bottom: 0.4rem;
  }

  .memo-next-text {
    font-size: 0.95rem;
    color: var(--navy);
    line-height: 1.6;
    margin: 0;
  }

  .memo-stage-grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 1rem;
  }

  .memo-stage-card {
    background: white;
    border: 1px solid var(--stone);
    border-radius: 8px;
    padding: 1.2rem 1.3rem;
  }

  .memo-stage-name {
    font-family: 'Fraunces', serif;
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--navy);
    display: block;
    margin-bottom: 0.4rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .memo-stage-score {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--navy);
    line-height: 1;
    margin-bottom: 0.6rem;
    font-family: 'Fraunces', serif;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .memo-stage-bar-track {
    height: 4px;
    background: var(--stone);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 0.9rem;
  }

  .memo-stage-bar-fill {
    height: 100%;
    background: var(--sage);
    border-radius: 2px;
  }

  .memo-stage-meta {
    font-size: 0.78rem;
    color: rgba(26,39,68,0.55);
    line-height: 1.5;
  }

  .memo-stage-meta div + div { margin-top: 0.25rem; }

  .memo-stage-meta strong {
    color: var(--navy);
    font-weight: 600;
  }

  .memo-sub-table {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .memo-sub-row {
    display: grid;
    grid-template-columns: 100px 1fr 60px 80px;
    gap: 1rem;
    align-items: center;
    padding: 0.7rem 0.9rem;
    background: rgba(26,39,68,0.025);
