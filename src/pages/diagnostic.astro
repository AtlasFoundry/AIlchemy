---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Makers Diagnostic — hideaway."
  description="A structured diagnostic to show where you are in your maker journey across Download, Idea, and Creation."
>

<!-- ─── INTRO ─────────────────────────────────────────────────── -->
<section id="view-intro" class="diag-view">
  <div class="intro-hero">
    <div class="intro-hero-inner">
      <div class="diag-tag">Diagnostic</div>
      <h1>Makers<span class="accent"> Diagnostic.</span></h1>
      <p class="intro-sub">This looks at how you currently move through making — across three stages: Download, Idea, and Creation.</p>
      <p class="intro-sub">The goal is not to judge potential. It is to show the pattern you are in now, so you know what to strengthen next.</p>
      <div class="intro-meta">
        <span>45 questions</span>
        <span>·</span>
        <span>~10 minutes</span>
        <span>·</span>
        <span>Your result: a Makers Passport</span>
      </div>
      <button class="btn-yellow btn-begin" id="btn-begin">Begin the diagnostic →</button>
    </div>
  </div>
  <div class="intro-stages">
    <div class="intro-stages-inner">
      <div class="stage-card">
        <span class="stage-num">01</span>
        <h3>Download.</h3>
        <p>Capturing, noticing, organising, and selecting. The habit of bringing useful material in.</p>
      </div>
      <div class="stage-card">
        <span class="stage-num">02</span>
        <h3>Idea.</h3>
        <p>Shaping, testing, clarifying, and deciding. The work of turning rough thoughts into something usable.</p>
      </div>
      <div class="stage-card">
        <span class="stage-num">03</span>
        <h3>Creation.</h3>
        <p>Building, finishing, releasing, and iterating. The move from concept to output.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── QUESTIONS ─────────────────────────────────────────────── -->
<section id="view-questions" class="diag-view" style="display:none;">
  <div class="q-chrome">
    <div class="q-progress-bar">
      <div class="q-progress-fill" id="q-progress-fill"></div>
    </div>
    <div class="q-stage-track" id="q-stage-track">
      <span class="q-stage-pill" data-stage="download">Download</span>
      <span class="q-stage-pill" data-stage="idea">Idea</span>
      <span class="q-stage-pill" data-stage="creation">Creation</span>
    </div>
  </div>

  <div class="q-body">
    <div class="q-meta">
      <span class="q-subdomain" id="q-subdomain"></span>
      <span class="q-counter" id="q-counter"></span>
    </div>
    <p class="q-text" id="q-text"></p>
    <div class="q-options" id="q-options"></div>
    <div class="q-nav">
      <button class="btn-ghost" id="btn-back">← Back</button>
      <button class="btn-yellow" id="btn-next" disabled>Next →</button>
    </div>
  </div>
</section>

<!-- ─── RESULTS ───────────────────────────────────────────────── -->
<section id="view-results" class="diag-view" style="display:none;">
  <div class="results-hero">
    <div class="results-hero-inner">
      <div class="diag-tag">Your result</div>
      <h1 id="res-band-heading">—</h1>
      <p class="res-overall-score" id="res-overall-score"></p>
      <p class="res-band-desc" id="res-band-desc"></p>
    </div>
  </div>

  <div class="results-body">
    <div class="results-body-inner">

      <div class="results-stages">
        <div class="results-stage-card" id="res-stage-download">
          <div class="rsc-header">
            <span class="rsc-label">Download.</span>
            <span class="rsc-score" id="rsc-score-download"></span>
          </div>
          <div class="rsc-bar-track"><div class="rsc-bar-fill" id="rsc-bar-download"></div></div>
          <p class="rsc-interp" id="rsc-interp-download"></p>
        </div>
        <div class="results-stage-card" id="res-stage-idea">
          <div class="rsc-header">
            <span class="rsc-label">Idea.</span>
            <span class="rsc-score" id="rsc-score-idea"></span>
          </div>
          <div class="rsc-bar-track"><div class="rsc-bar-fill" id="rsc-bar-idea"></div></div>
          <p class="rsc-interp" id="rsc-interp-idea"></p>
        </div>
        <div class="results-stage-card" id="res-stage-creation">
          <div class="rsc-header">
            <span class="rsc-label">Creation.</span>
            <span class="rsc-score" id="rsc-score-creation"></span>
          </div>
          <div class="rsc-bar-track"><div class="rsc-bar-fill" id="rsc-bar-creation"></div></div>
          <p class="rsc-interp" id="rsc-interp-creation"></p>
        </div>
      </div>

      <div class="results-pattern">
        <div class="pattern-card">
          <span class="pattern-label">Strongest stage</span>
          <span class="pattern-value" id="res-strongest"></span>
        </div>
        <div class="pattern-card">
          <span class="pattern-label">Main gap</span>
          <span class="pattern-value" id="res-gap"></span>
        </div>
        <div class="pattern-card pattern-card--wide">
          <span class="pattern-label">Best next move</span>
          <span class="pattern-value" id="res-next-move"></span>
        </div>
      </div>

      <div class="results-cta">
        <button class="btn-yellow" id="btn-view-passport">View your Makers Passport →</button>
        <button class="btn-ghost" id="btn-retake">Retake</button>
      </div>

    </div>
  </div>
</section>

<!-- ─── MAKERS PASSPORT ───────────────────────────────────────── -->
<section id="view-passport" class="diag-view" style="display:none;">
  <div class="passport-wrapper">
    <div class="passport" id="passport">

      <div class="passport-header">
        <div class="passport-logo"><span class="logo-h">h</span><span class="logo-idea">idea</span><span class="logo-way">way.</span></div>
        <div class="passport-title-block">
          <h1>Makers Passport</h1>
          <p class="passport-date" id="passport-date"></p>
        </div>
      </div>

      <div class="passport-overview">
        <div class="passport-score-block">
          <span class="passport-score-label">Overall score</span>
          <span class="passport-score-value" id="pp-overall-score"></span>
        </div>
        <div class="passport-band-block">
          <span class="passport-band-name" id="pp-band-name"></span>
          <span class="passport-band-desc" id="pp-band-desc"></span>
        </div>
        <div class="passport-profile-block">
          <span class="passport-profile-label">Profile</span>
          <span class="passport-profile-name" id="pp-profile-name"></span>
        </div>
      </div>

      <div class="passport-stages">
        <div class="passport-stage">
          <div class="pst-header">
            <span class="pst-name">Download.</span>
            <span class="pst-score" id="pp-score-download"></span>
          </div>
          <div class="pst-bar-track"><div class="pst-bar-fill" id="pp-bar-download"></div></div>
          <p class="pst-meaning" id="pp-meaning-download"></p>
          <div class="pst-route" id="pp-route-download"></div>
        </div>
        <div class="passport-stage">
          <div class="pst-header">
            <span class="pst-name">Idea.</span>
            <span class="pst-score" id="pp-score-idea"></span>
          </div>
          <div class="pst-bar-track"><div class="pst-bar-fill" id="pp-bar-idea"></div></div>
          <p class="pst-meaning" id="pp-meaning-idea"></p>
          <div class="pst-route" id="pp-route-idea"></div>
        </div>
        <div class="passport-stage">
          <div class="pst-header">
            <span class="pst-name">Creation.</span>
            <span class="pst-score" id="pp-score-creation"></span>
          </div>
          <div class="pst-bar-track"><div class="pst-bar-fill" id="pp-bar-creation"></div></div>
          <p class="pst-meaning" id="pp-meaning-creation"></p>
          <div class="pst-route" id="pp-route-creation"></div>
        </div>
      </div>

      <div class="passport-next">
        <div class="passport-next-inner">
          <h2>What to work on next</h2>
          <p class="passport-gap-label">Main gap: <strong id="pp-gap"></strong></p>
          <p class="passport-next-move" id="pp-next-move"></p>
        </div>
      </div>

    </div>

    <div class="passport-actions">
      <button class="btn-yellow" onclick="window.print()">Print / Save as PDF</button>
      <button class="btn-ghost" id="btn-back-results">← Back to results</button>
      <button class="btn-ghost" id="btn-retake-2">Start again</button>
    </div>
  </div>
</section>

</BaseLayout>

<style>
  /* ── base ─────────────────────────────────── */
  .diag-view { min-height: 100vh; }

  .diag-tag {
    display: inline-block;
    background: rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.6);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 0.3rem 0.7rem;
    border-radius: 4px;
    margin-bottom: 1.5rem;
  }

  /* ── intro ────────────────────────────────── */
  .intro-hero {
    background: var(--navy);
    padding: 9rem 3rem 5rem;
  }

  .intro-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .intro-hero h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2.8rem, 6vw, 4.5rem);
    font-weight: 500;
    color: white;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .accent { color: #E8F547; }

  .intro-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.65);
    line-height: 1.7;
    max-width: 580px;
    margin: 0 0 0.8rem;
  }

  .intro-meta {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    margin: 1.5rem 0 2.2rem;
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
  }

  .btn-begin {
    font-size: 1rem;
    padding: 0.8rem 2rem;
    border: none;
    cursor: pointer;
  }

  .intro-stages {
    background: var(--frosted);
    padding: 4rem 3rem;
  }

  .intro-stages-inner {
    max-width: 900px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .stage-card {
    padding: 2rem 1.8rem;
    background: white;
    border: 1px solid var(--stone);
    border-radius: 10px;
  }

  .stage-num {
    display: block;
    font-family: 'Fraunces', serif;
    font-size: 1.8rem;
    font-weight: 300;
    color: var(--sage);
    margin-bottom: 0.6rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .stage-card h3 {
    font-family: 'Fraunces', serif;
    font-size: 1.3rem;
    font-weight: 500;
    color: var(--navy);
    margin: 0 0 0.6rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .stage-card p {
    font-size: 0.9rem;
    color: rgba(26,39,68,0.6);
    line-height: 1.6;
    margin: 0;
  }

  /* ── questions ────────────────────────────── */
  .q-chrome {
    background: var(--navy);
    padding: 4.5rem 3rem 1.5rem;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  .q-progress-bar {
    height: 3px;
    background: rgba(255,255,255,0.12);
    border-radius: 2px;
    margin-bottom: 1.2rem;
    overflow: hidden;
  }

  .q-progress-fill {
    height: 100%;
    background: #E8F547;
    border-radius: 2px;
    transition: width 0.3s ease;
    width: 0%;
  }

  .q-stage-track {
    display: flex;
    gap: 0.6rem;
  }

  .q-stage-pill {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255,255,255,0.3);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    border: 1px solid rgba(255,255,255,0.12);
    transition: all 0.2s;
  }

  .q-stage-pill.active {
    color: white;
    border-color: rgba(255,255,255,0.4);
    background: rgba(255,255,255,0.08);
  }

  .q-stage-pill.done {
    color: var(--sage);
    border-color: var(--sage);
    background: rgba(156,175,136,0.1);
  }

  .q-body {
    background: var(--frosted);
    min-height: calc(100vh - 120px);
    padding: 4rem 3rem 5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .q-meta {
    width: 100%;
    max-width: 640px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 2rem;
  }

  .q-subdomain {
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--sage);
  }

  .q-counter {
    font-size: 0.78rem;
    color: rgba(26,39,68,0.4);
  }

  .q-text {
    width: 100%;
    max-width: 640px;
    font-family: 'Fraunces', serif;
    font-size: clamp(1.3rem, 3vw, 1.8rem);
    font-weight: 400;
    color: var(--navy);
    line-height: 1.4;
    margin: 0 0 2.5rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .q-options {
    width: 100%;
    max-width: 640px;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
    margin-bottom: 2.5rem;
  }

  .q-option {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem 1.2rem;
    background: white;
    border: 2px solid var(--stone);
    border-radius: 8px;
    cursor: pointer;
    transition: border-color 0.2s, background 0.2s;
  }

  .q-option:hover { border-color: var(--sage); }

  .q-option.selected {
    border-color: var(--navy);
    background: rgba(26,39,68,0.04);
  }

  .q-option input[type="radio"] {
    width: 18px;
    height: 18px;
    accent-color: var(--navy);
    flex-shrink: 0;
    cursor: pointer;
  }

  .q-option-label {
    font-size: 0.95rem;
    color: var(--navy);
    line-height: 1.4;
    cursor: pointer;
  }

  .q-nav {
    width: 100%;
    max-width: 640px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  /* ── shared buttons ───────────────────────── */
  .btn-yellow {
    display: inline-block;
    background: #E8F547;
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.92rem;
    padding: 0.7rem 1.6rem;
    border-radius: 7px;
    text-decoration: none;
    border: none;
    cursor: pointer;
    transition: background 0.2s;
  }

  .btn-yellow:hover { background: #d4e03a; }
  .btn-yellow:disabled { opacity: 0.4; cursor: not-allowed; }

  .btn-ghost {
    background: transparent;
    border: 2px solid var(--stone);
    color: var(--navy);
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    padding: 0.65rem 1.3rem;
    border-radius: 7px;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .btn-ghost:hover { border-color: var(--navy); }

  /* ── results ──────────────────────────────── */
  .results-hero {
    background: var(--navy);
    padding: 9rem 3rem 4rem;
  }

  .results-hero-inner {
    max-width: 720px;
    margin: 0 auto;
  }

  .results-hero h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 5vw, 3.5rem);
    font-weight: 500;
    color: #E8F547;
    margin: 0 0 0.5rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .res-overall-score {
    font-size: 1rem;
    color: rgba(255,255,255,0.5);
    margin: 0 0 1rem;
  }

  .res-band-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.7);
    line-height: 1.6;
    max-width: 520px;
    margin: 0;
  }

  .results-body {
    background: var(--frosted);
    padding: 4rem 3rem 5rem;
  }

  .results-body-inner {
    max-width: 760px;
    margin: 0 auto;
  }

  .results-stages {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
    margin-bottom: 2.5rem;
  }

  .results-stage-card {
    background: white;
    border: 1px solid var(--stone);
    border-radius: 10px;
    padding: 1.5rem 1.8rem;
  }

  .rsc-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.8rem;
  }

  .rsc-label {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--navy);
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .rsc-score {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--navy);
  }

  .rsc-bar-track {
    height: 6px;
    background: var(--stone);
    border-radius: 3px;
    margin-bottom: 0.9rem;
    overflow: hidden;
  }

  .rsc-bar-fill {
    height: 100%;
    background: var(--sage);
    border-radius: 3px;
    transition: width 0.6s ease;
    width: 0%;
  }

  .rsc-interp {
    font-size: 0.9rem;
    color: rgba(26,39,68,0.65);
    line-height: 1.6;
    margin: 0;
  }

  .results-pattern {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }

  .pattern-card {
    background: white;
    border: 1px solid var(--stone);
    border-radius: 10px;
    padding: 1.3rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .pattern-card--wide { grid-column: 1 / -1; }

  .pattern-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(26,39,68,0.4);
  }

  .pattern-value {
    font-size: 0.95rem;
    color: var(--navy);
    line-height: 1.5;
  }

  .results-cta {
    display: flex;
    gap: 0.8rem;
    align-items: center;
    flex-wrap: wrap;
  }

  /* ── passport ─────────────────────────────── */
  .passport-wrapper {
    background: var(--frosted);
    padding: 4rem 3rem 5rem;
  }

  .passport {
    max-width: 800px;
    margin: 0 auto 2rem;
    background: white;
    border: 1px solid var(--stone);
    border-radius: 12px;
    overflow: hidden;
  }

  .passport-header {
    background: var(--navy);
    padding: 2rem 2.5rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .passport-logo {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 500;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .logo-h   { color: var(--sage); }
  .logo-idea { color: #E8F547; }
  .logo-way  { color: var(--sage); }

  .passport-title-block { text-align: right; }

  .passport-title-block h1 {
    font-family: 'Fraunces', serif;
    font-size: 1.5rem;
    font-weight: 400;
    color: white;
    margin: 0 0 0.2rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .passport-date {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.4);
    margin: 0;
  }

  .passport-overview {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 2rem;
    padding: 2rem 2.5rem;
    background: rgba(26,39,68,0.03);
    border-bottom: 1px solid var(--stone);
    align-items: start;
  }

  .passport-score-block,
  .passport-profile-block {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .passport-score-label,
  .passport-profile-label {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(26,39,68,0.4);
  }

  .passport-score-value {
    font-family: 'Fraunces', serif;
    font-size: 2.2rem;
    font-weight: 400;
    color: var(--navy);
    line-height: 1;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .passport-band-block {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .passport-band-name {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--navy);
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .passport-band-desc {
    font-size: 0.88rem;
    color: rgba(26,39,68,0.6);
    line-height: 1.5;
  }

  .passport-profile-name {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--navy);
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .passport-stages {
    padding: 2rem 2.5rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    border-bottom: 1px solid var(--stone);
  }

  .passport-stage { }

  .pst-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 0.5rem;
  }

  .pst-name {
    font-family: 'Fraunces', serif;
    font-size: 1rem;
    font-weight: 500;
    color: var(--navy);
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .pst-score {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--navy);
  }

  .pst-bar-track {
    height: 5px;
    background: var(--stone);
    border-radius: 3px;
    margin-bottom: 0.7rem;
    overflow: hidden;
  }

  .pst-bar-fill {
    height: 100%;
    background: var(--sage);
    border-radius: 3px;
    width: 0%;
  }

  .pst-meaning {
    font-size: 0.88rem;
    color: rgba(26,39,68,0.65);
    line-height: 1.6;
    margin: 0 0 0.5rem;
  }

  .pst-route {
    font-size: 0.78rem;
    color: var(--sage);
    font-weight: 600;
  }

  .pst-route a {
    color: var(--sage);
    text-decoration: none;
    border-bottom: 1px solid var(--sage);
  }

  .passport-next {
    padding: 2rem 2.5rem;
    background: var(--navy);
  }

  .passport-next h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.1rem;
    font-weight: 500;
    color: white;
    margin: 0 0 0.8rem;
    font-optical-sizing: none;
    font-feature-settings: normal;
  }

  .passport-gap-label {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.5);
    margin: 0 0 0.6rem;
  }

  .passport-gap-label strong { color: rgba(255,255,255,0.8); }

  .passport-next-move {
    font-size: 0.95rem;
    color: rgba(255,255,255,0.8);
    line-height: 1.65;
    margin: 0;
  }

  .passport-actions {
    max-width: 800px;
    margin: 0 auto;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── responsive ───────────────────────────── */
  @media (max-width: 700px) {
    .intro-hero { padding: 8rem 1.5rem 4rem; }
    .intro-stages { padding: 3rem 1.5rem; }
    .intro-stages-inner { grid-template-columns: 1fr; }
    .q-body { padding: 2.5rem 1.5rem 4rem; }
    .q-chrome { padding: 4rem 1.5rem 1.2rem; }
    .results-hero { padding: 8rem 1.5rem 3rem; }
    .results-body { padding: 3rem 1.5rem; }
    .results-pattern { grid-template-columns: 1fr; }
    .passport-wrapper { padding: 3rem 1.5rem; }
    .passport-header { flex-direction: column; gap: 1rem; align-items: flex-start; }
    .passport-title-block { text-align: left; }
    .passport-overview { grid-template-columns: 1fr; gap: 1.2rem; }
    .passport-stages, .passport-next { padding: 1.5rem; }
  }

  /* ── print ────────────────────────────────── */
  @media print {
    #view-intro, #view-questions, #view-results { display: none !important; }
    #view-passport { display: block !important; }
    .passport-actions { display: none !important; }
    nav, footer { display: none !important; }
    .passport-wrapper { padding: 0; background: white; }
    .passport {
      border: none;
      border-radius: 0;
      max-width: 100%;
      box-shadow: none;
    }
    .pst-bar-fill, .rsc-bar-fill { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  }
</style>

<script>
// ─────────────────────────────────────────────────────────────────
// DATA
// ─────────────────────────────────────────────────────────────────
const STAGES = {
  download: { name: 'Download', weight: 0.33 },
  idea:     { name: 'Idea',     weight: 0.33 },
  creation: { name: 'Creation', weight: 0.34 },
};

const SCALE = [
  { score: 1, label: 'Not true yet' },
  { score: 2, label: 'Rarely' },
  { score: 3, label: 'Sometimes' },
  { score: 4, label: 'Mostly' },
  { score: 5, label: 'Consistently' },
];

const QUESTIONS = [
  // ── Download: Capture habit ──────────────────
  { id: 'HD01', stage: 'download', subdomain: 'Capture habit',     text: 'I capture useful ideas before they vanish.' },
  { id: 'HD02', stage: 'download', subdomain: 'Capture habit',     text: 'I notice when something is worth writing down.' },
  { id: 'HD03', stage: 'download', subdomain: 'Capture habit',     text: 'I have a dependable place to put raw ideas.' },
  { id: 'HD04', stage: 'download', subdomain: 'Capture habit',     text: 'I capture things in a way that makes sense later.' },
  // ── Download: Pattern awareness ─────────────
  { id: 'HD05', stage: 'download', subdomain: 'Pattern awareness', text: 'I can spot repeated themes in what I collect.' },
  { id: 'HD06', stage: 'download', subdomain: 'Pattern awareness', text: 'I can tell the difference between noise and signal.' },
  { id: 'HD07', stage: 'download', subdomain: 'Pattern awareness', text: 'I can recognise when several notes are pointing to one idea.' },
  { id: 'HD08', stage: 'download', subdomain: 'Pattern awareness', text: 'I collect examples, not just abstract thoughts.' },
  // ── Download: Organisation ───────────────────
  { id: 'HD09', stage: 'download', subdomain: 'Organisation',      text: 'I can find old notes or prompts when I need them.' },
  { id: 'HD10', stage: 'download', subdomain: 'Organisation',      text: 'My inputs are grouped or tagged in a usable way.' },
  { id: 'HD11', stage: 'download', subdomain: 'Organisation',      text: 'My capture system does not feel chaotic or scattered.' },
  { id: 'HD12', stage: 'download', subdomain: 'Organisation',      text: 'I revisit what I captured rather than leaving it buried.' },
  // ── Download: Selection ─────────────────────
  { id: 'HD13', stage: 'download', subdomain: 'Selection',         text: 'I know which ideas deserve another look.' },
  { id: 'HD14', stage: 'download', subdomain: 'Selection',         text: 'I can choose one promising thread without losing everything else.' },
  { id: 'HD15', stage: 'download', subdomain: 'Selection',         text: 'I do not confuse collecting with actual progress.' },
  // ── Idea: Concept formation ─────────────────
  { id: 'HI01', stage: 'idea',     subdomain: 'Concept formation', text: 'I can turn a rough thought into a clearer concept.' },
  { id: 'HI02', stage: 'idea',     subdomain: 'Concept formation', text: 'I can explain what the idea is trying to do.' },
  { id: 'HI03', stage: 'idea',     subdomain: 'Concept formation', text: 'I can identify the core problem underneath the idea.' },
  { id: 'HI04', stage: 'idea',     subdomain: 'Concept formation', text: 'I can make the idea more specific without killing it.' },
  // ── Idea: Pressure testing ──────────────────
  { id: 'HI05', stage: 'idea',     subdomain: 'Pressure testing',  text: 'I test whether the idea is actually useful.' },
  { id: 'HI06', stage: 'idea',     subdomain: 'Pressure testing',  text: 'I can challenge my own assumptions about an idea.' },
  { id: 'HI07', stage: 'idea',     subdomain: 'Pressure testing',  text: 'I compare the idea against alternatives before moving ahead.' },
  { id: 'HI08', stage: 'idea',     subdomain: 'Pressure testing',  text: 'I can see where an idea is weak before I build.' },
  // ── Idea: Purpose clarity ───────────────────
  { id: 'HI09', stage: 'idea',     subdomain: 'Purpose clarity',   text: 'I can describe who or what the idea is for.' },
  { id: 'HI10', stage: 'idea',     subdomain: 'Purpose clarity',   text: 'I can explain why this idea matters now.' },
  { id: 'HI11', stage: 'idea',     subdomain: 'Purpose clarity',   text: 'I can state the value of the idea in plain language.' },
  { id: 'HI12', stage: 'idea',     subdomain: 'Purpose clarity',   text: 'I can tell when an idea sounds interesting but lacks purpose.' },
  // ── Idea: Decision making ───────────────────
  { id: 'HI13', stage: 'idea',     subdomain: 'Decision making',   text: 'I know how to choose which idea gets time first.' },
  { id: 'HI14', stage: 'idea',     subdomain: 'Decision making',   text: 'I can stop polishing an idea that is not strong enough.' },
  { id: 'HI15', stage: 'idea',     subdomain: 'Decision making',   text: 'I can decide when an idea is ready to move into build.' },
  // ── Creation: Translation into action ───────
  { id: 'HC01', stage: 'creation', subdomain: 'Translation into action',  text: 'I can move from concept to a first practical step.' },
  { id: 'HC02', stage: 'creation', subdomain: 'Translation into action',  text: 'I can break an idea into buildable parts.' },
  { id: 'HC03', stage: 'creation', subdomain: 'Translation into action',  text: 'I know what the first version needs and what it does not.' },
  { id: 'HC04', stage: 'creation', subdomain: 'Translation into action',  text: 'I can begin building without waiting for perfect clarity.' },
  // ── Creation: Tool fluency ──────────────────
  { id: 'HC05', stage: 'creation', subdomain: 'Tool fluency',      text: 'I know which tools suit the thing I am making.' },
  { id: 'HC06', stage: 'creation', subdomain: 'Tool fluency',      text: 'I can use AI or other tools with enough confidence to make progress.' },
  { id: 'HC07', stage: 'creation', subdomain: 'Tool fluency',      text: 'I do not get lost in tool-hopping once I start.' },
  { id: 'HC08', stage: 'creation', subdomain: 'Tool fluency',      text: 'I can keep the build process simple enough to continue.' },
  // ── Creation: Completion and release ────────
  { id: 'HC09', stage: 'creation', subdomain: 'Completion and release', text: 'I finish useful outputs rather than leaving loose ends.' },
  { id: 'HC10', stage: 'creation', subdomain: 'Completion and release', text: 'I can decide when something is ready to share.' },
  { id: 'HC11', stage: 'creation', subdomain: 'Completion and release', text: 'I can release work without endless reworking.' },
  { id: 'HC12', stage: 'creation', subdomain: 'Completion and release', text: 'I can make things that are usable, not just interesting.' },
  // ── Creation: Iteration ─────────────────────
  { id: 'HC13', stage: 'creation', subdomain: 'Iteration',         text: 'I learn from what I build.' },
  { id: 'HC14', stage: 'creation', subdomain: 'Iteration',         text: 'I can improve a first version rather than abandoning it.' },
  { id: 'HC15', stage: 'creation', subdomain: 'Iteration',         text: 'I can keep momentum after the first release.' },
];

// ─────────────────────────────────────────────────────────────────
// SCORING ENGINE
// ─────────────────────────────────────────────────────────────────
function normalise(score) {
  // Maps 1–5 to 0–100
  return ((score - 1) / 4) * 100;
}

function calcStageScore(answers, stage) {
  const qs = QUESTIONS.filter(q => q.stage === stage);
  const scores = qs.map(q => answers[q.id] || 0).filter(s => s > 0);
  if (scores.length === 0) return 0;
  const avg = scores.reduce((a, b) => a + b, 0) / scores.length;
  return normalise(avg);
}

function calcOverall(stageScores) {
  return (
    stageScores.download * STAGES.download.weight +
    stageScores.idea     * STAGES.idea.weight +
    stageScores.creation * STAGES.creation.weight
  );
}

function getBand(score) {
  if (score >= 75) return { name: 'Established Maker',  desc: 'You have strong, consistent habits across the making process. The work now is to refine and deepen.' };
  if (score >= 55) return { name: 'Practising Maker',   desc: 'Your making process is developing well. There are clear strengths and one or two stages that need more consistent work.' };
  if (score >= 35) return { name: 'Developing Maker',   desc: 'You are building the foundations. Progress is happening, but some stages are still inconsistent or underdeveloped.' };
  return              { name: 'Emerging Maker',      desc: 'You are at the beginning of building a reliable making process. The most valuable work right now is establishing the basics.' };
}

function getStageInterpretation(stage, score) {
  const bands = {
    download: {
      high:   'Capture is working well. You bring in useful material and can find it again.',
      mid:    'Your capture habit is developing. Some inputs get lost or stay unreviewed.',
      low:    'Inputs are getting lost or staying buried. The capture system needs strengthening.',
    },
    idea: {
      high:   'You shape ideas well — moving from rough to specific and knowing when to act.',
      mid:    'Ideas are forming, but the pressure-testing and decision-making steps are inconsistent.',
      low:    'Ideas tend to stay vague or drift. The shaping process is the main gap right now.',
    },
    creation: {
      high:   'You build things and see them through. Completion and iteration are working.',
      mid:    'You start well but finishing and releasing consistently needs more work.',
      low:    'Work starts but rarely reaches a usable output. The build stage is where things stall.',
    },
  };
  const b = bands[stage];
  if (score >= 65) return b.high;
  if (score >= 40) return b.mid;
  return b.low;
}

function getStageMeaning(stage, score) {
  const meanings = {
    download: {
      high:   'Useful material is captured and easy to return to.',
      mid:    'Some useful material gets through, but the system is not yet reliable.',
      low:    'Inputs get lost, buried, or never revisited.',
    },
    idea: {
      high:   'Ideas become specific enough to judge and choose from.',
      mid:    'Some ideas get clear, but many stay half-formed.',
      low:    'Concepts stay vague or drift without resolution.',
    },
    creation: {
      high:   'Ideas become things and keep improving after the first release.',
      mid:    'Things get built, but not always finished or shared.',
      low:    'Work starts but rarely becomes a useful output.',
    },
  };
  const m = meanings[stage];
  if (score >= 65) return m.high;
  if (score >= 40) return m.mid;
  return m.low;
}

function getNextMove(weakestStage) {
  const moves = {
    download: 'Choose one capture tool and one review rhythm. Use them consistently for two weeks before changing anything.',
    idea:     'Take one idea you have been sitting on and write a single paragraph: the problem, the user, and why it matters now.',
    creation: 'Pick the smallest possible first version of your current idea. Build that first — before refining, before polishing, before sharing.',
  };
  return moves[weakestStage];
}

function getStageRoute(stage) {
  const routes = {
    download: { label: 'Explore Download resources →', href: '/library?stage=download' },
    idea:     { label: 'Explore Idea resources →',     href: '/library?stage=idea' },
    creation: { label: 'Explore Creation resources →', href: '/library?stage=creation' },
  };
  return routes[stage];
}

function computeResults(answers) {
  const stageScores = {
    download: calcStageScore(answers, 'download'),
    idea:     calcStageScore(answers, 'idea'),
    creation: calcStageScore(answers, 'creation'),
  };
  const overall = calcOverall(stageScores);
  const band = getBand(overall);

  const entries = Object.entries(stageScores);
  const strongest = entries.reduce((a, b) => b[1] > a[1] ? b : a)[0];
  const weakest   = entries.reduce((a, b) => b[1] < a[1] ? b : a)[0];

  return {
    stageScores,
    overall,
    band,
    strongest,
    weakest,
    profileName: STAGES[strongest].name,
    nextMove: getNextMove(weakest),
  };
}

// ─────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────
const STORAGE_KEY = 'hideaway_diag_v1';

function loadState() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || { answers: {}, currentQ: 0 }; }
  catch { return { answers: {}, currentQ: 0 }; }
}

function saveState(state) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
}

function clearState() {
  localStorage.removeItem(STORAGE_KEY);
}

// ─────────────────────────────────────────────────────────────────
// VIEWS
// ─────────────────────────────────────────────────────────────────
const VIEWS = ['intro', 'questions', 'results', 'passport'];

function showView(name) {
  VIEWS.forEach(v => {
    const el = document.getElementById(`view-${v}`);
    if (el) el.style.display = v === name ? 'block' : 'none';
  });
  window.scrollTo(0, 0);
}

// ─────────────────────────────────────────────────────────────────
// QUESTION RENDERER
// ─────────────────────────────────────────────────────────────────
let state = loadState();

function renderQuestion(index) {
  const q = QUESTIONS[index];
  if (!q) return;

  // Progress
  const pct = (index / QUESTIONS.length) * 100;
  document.getElementById('q-progress-fill').style.width = `${pct}%`;

  // Stage pills
  const stageOrder = ['download', 'idea', 'creation'];
  const currentStageIndex = stageOrder.indexOf(q.stage);
  document.querySelectorAll('.q-stage-pill').forEach((pill, i) => {
    pill.classList.remove('active', 'done');
    if (i < currentStageIndex) pill.classList.add('done');
    if (i === currentStageIndex) pill.classList.add('active');
  });

  // Meta
  const stageQs = QUESTIONS.filter(x => x.stage === q.stage);
  const stageQIndex = stageQs.findIndex(x => x.id === q.id) + 1;
  document.getElementById('q-subdomain').textContent = q.subdomain;
  document.getElementById('q-counter').textContent = `${STAGES[q.stage].name} · ${stageQIndex} of ${stageQs.length}`;

  // Question text
  document.getElementById('q-text').textContent = q.text;

  // Options
  const container = document.getElementById('q-options');
  const existing = state.answers[q.id];
  container.innerHTML = SCALE.map(opt => `
    <label class="q-option${existing === opt.score ? ' selected' : ''}">
      <input type="radio" name="q-response" value="${opt.score}" ${existing === opt.score ? 'checked' : ''} />
      <span class="q-option-label">${opt.label}</span>
    </label>
  `).join('');

  // Wire up options
  container.querySelectorAll('input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      state.answers[q.id] = parseInt(radio.value);
      saveState(state);
      container.querySelectorAll('.q-option').forEach(o => o.classList.remove('selected'));
      radio.closest('.q-option').classList.add('selected');
      document.getElementById('btn-next').disabled = false;
    });
  });

  // Next button state
  document.getElementById('btn-next').disabled = !existing;

  // Back button
  document.getElementById('btn-back').style.visibility = index === 0 ? 'hidden' : 'visible';
}

// ─────────────────────────────────────────────────────────────────
// RESULTS RENDERER
// ─────────────────────────────────────────────────────────────────
function renderResults() {
  const r = computeResults(state.answers);

  // Hero
  document.getElementById('res-band-heading').textContent = r.band.name;
  document.getElementById('res-overall-score').textContent = `Overall score: ${Math.round(r.overall)}%`;
  document.getElementById('res-band-desc').textContent = r.band.desc;

  // Stage cards
  ['download', 'idea', 'creation'].forEach(stage => {
    const score = Math.round(r.stageScores[stage]);
    document.getElementById(`rsc-score-${stage}`).textContent = `${score}%`;
    document.getElementById(`rsc-bar-${stage}`).style.width = `${score}%`;
    document.getElementById(`rsc-interp-${stage}`).textContent = getStageInterpretation(stage, r.stageScores[stage]);
  });

  // Pattern
  document.getElementById('res-strongest').textContent = STAGES[r.strongest].name;
  document.getElementById('res-gap').textContent = STAGES[r.weakest].name;
  document.getElementById('res-next-move').textContent = r.nextMove;
}

// ─────────────────────────────────────────────────────────────────
// PASSPORT RENDERER
// ─────────────────────────────────────────────────────────────────
function renderPassport() {
  const r = computeResults(state.answers);

  // Date
  document.getElementById('passport-date').textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

  // Overview
  document.getElementById('pp-overall-score').textContent = `${Math.round(r.overall)}%`;
  document.getElementById('pp-band-name').textContent = r.band.name;
  document.getElementById('pp-band-desc').textContent = r.band.desc;
  document.getElementById('pp-profile-name').textContent = r.profileName;

  // Stages
  ['download', 'idea', 'creation'].forEach(stage => {
    const score = Math.round(r.stageScores[stage]);
    const route = getStageRoute(stage);
    document.getElementById(`pp-score-${stage}`).textContent = `${score}%`;
    document.getElementById(`pp-bar-${stage}`).style.width = `${score}%`;
    document.getElementById(`pp-meaning-${stage}`).textContent = getStageMeaning(stage, r.stageScores[stage]);
    document.getElementById(`pp-route-${stage}`).innerHTML = `<a href="${route.href}">${route.label}</a>`;
  });

  // Next move
  document.getElementById('pp-gap').textContent = STAGES[r.weakest].name;
  document.getElementById('pp-next-move').textContent = r.nextMove;
}

// ─────────────────────────────────────────────────────────────────
// EVENT WIRING
// ─────────────────────────────────────────────────────────────────
document.getElementById('btn-begin').addEventListener('click', () => {
  showView('questions');
  renderQuestion(state.currentQ);
});

document.getElementById('btn-next').addEventListener('click', () => {
  const next = state.currentQ + 1;
  if (next >= QUESTIONS.length) {
    renderResults();
    showView('results');
  } else {
    state.currentQ = next;
    saveState(state);
    renderQuestion(next);
  }
});

document.getElementById('btn-back').addEventListener('click', () => {
  if (state.currentQ > 0) {
    state.currentQ -= 1;
    saveState(state);
    renderQuestion(state.currentQ);
  }
});

document.getElementById('btn-view-passport').addEventListener('click', () => {
  renderPassport();
  showView('passport');
});

document.getElementById('btn-back-results').addEventListener('click', () => {
  renderResults();
  showView('results');
});

function retake() {
  clearState();
  state = { answers: {}, currentQ: 0 };
  showView('intro');
}

document.getElementById('btn-retake').addEventListener('click', retake);
document.getElementById('btn-retake-2').addEventListener('click', retake);

// Restore in-progress session
if (state.currentQ > 0 || Object.keys(state.answers).length > 0) {
  const allDone = Object.keys(state.answers).length === QUESTIONS.length;
  if (allDone) {
    renderResults();
    showView('results');
  } else {
    showView('questions');
    renderQuestion(state.currentQ);
  }
}
</script>
</BaseLayout>
