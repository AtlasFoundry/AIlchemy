  }

  .memo-actions {
    max-width: 860px;
    margin: 0 auto;
    display: flex;
    gap: 0.8rem;
    flex-wrap: wrap;
    align-items: center;
  }

  /* ── responsive ───────────────────────────── */
  @media (max-width: 700px) {
    .intro-hero { padding: 8rem 1.5rem 4rem; }
    .intro-stages { padding: 3rem 1.5rem; }
    .intro-stages-inner { grid-template-columns: 1fr; }

    .q-chrome { padding: 4rem 1.5rem 1.3rem; }
    .q-stage-segments { gap: 0.7rem; }
    .q-seg-label { font-size: 0.62rem; letter-spacing: 0.08em; }
    .q-body { padding: 2.5rem 1.5rem 4rem; }

    .q-meta { flex-direction: column; gap: 0.6rem; }
    .q-counter { align-self: flex-start; }
    .q-option { padding: 0.9rem 1.1rem 0.9rem 1.2rem; }

    .interstitial-wrapper { padding: 6rem 1.5rem 4rem; }

    .memo-wrapper { padding: 6rem 1.2rem 4rem; }
    .memo-header { flex-direction: column; gap: 1rem; align-items: flex-start; padding: 1.6rem 1.5rem; }
    .memo-title-block { text-align: left; }
    .memo-overview { grid-template-columns: 1fr; gap: 1.2rem; padding: 1.6rem 1.5rem; }
    .memo-section { padding: 1.6rem 1.5rem; }
    .memo-stage-grid { grid-template-columns: 1fr; }
    .memo-sub-row { grid-template-columns: 70px 1fr 50px 70px; gap: 0.6rem; font-size: 0.8rem; padding: 0.6rem 0.7rem; }
    .memo-resource-card { grid-template-columns: 1fr; }
    .memo-resource-meta { text-align: left; }
  }

  /* ── print ────────────────────────────────── */
  @media print {
    #view-intro, #view-questions, #view-interstitial { display: none !important; }
    #view-memo { display: block !important; }
    .memo-actions { display: none !important; }
    nav, footer { display: none !important; }
    .memo-wrapper { padding: 0; background: white; }
    .memo {
      border: none;
      border-radius: 0;
      max-width: 100%;
      box-shadow: none;
    }
    .memo-stage-bar-fill { print-color-adjust: exact; -webkit-print-color-adjust: exact; }
  }
</style>

<script define:vars={{ rawQuestions, rawSubdomains, rawStages, rawPatterns }}>
// ─────────────────────────────────────────────────────────────────
// DATA — Makers Memo v3 (loaded from /src/content/memo/*.json)
// ─────────────────────────────────────────────────────────────────
const STAGE_ID = { Download: 'download', Idea: 'idea', Creation: 'creation' };
const SUB_ID = {
  'Capture habit': 'capture',
  'Pattern awareness': 'pattern',
  'Organisation': 'organisation',
  'Selection': 'selection',
  'Concept formation': 'concept',
  'Pressure testing': 'pressure',
  'Purpose clarity': 'purpose',
  'Decision making': 'decision',
  'Translation into action': 'translation',
  'Tool fluency': 'tools',
  'Completion and release': 'completion',
  'Iteration': 'iteration',
};
const PATTERN_KEY = {
  'Even Maker': 'even',
  'The Collector': 'collector',
  'The Thinker': 'thinker',
  'The Builder': 'builder',
  'Stuck Upstream': 'stuckUpstream',
  'Stuck Midstream': 'stuckMidstream',
  'Rushed Maker': 'rushed',
  'Developing Maker': 'developing',
};

const STAGES = rawStages.map(s => ({
  id: STAGE_ID[s.id],
  label: s.id,
  weight: s.weight,
  shape: 'Diverge → Converge',
}));

const STAGE_WEIGHT = STAGES.reduce((acc, s) => { acc[s.id] = s.weight; return acc; }, {});

const SUBDOMAINS = rawSubdomains.map(s => ({
  id: SUB_ID[s.label],
  stage: STAGE_ID[s.stage],
  label: s.label,
  desc: s.desc,
}));

const QUESTIONS = rawQuestions
  .slice()
  .sort((a, b) => a.order - b.order)
  .map(q => ({
    id: q.id,
    stage: STAGE_ID[q.stage],
    subdomain: SUB_ID[q.subdomain],
    type: q.type,
    comb: q.comb,
    weight: q.weight,
    stem: q.stem,
    options: q.options,
    resourceTag: q.resourceTag,
  }));

// ─────────────────────────────────────────────────────────────────
// PATTERNS
// ─────────────────────────────────────────────────────────────────
const PATTERNS = rawPatterns.reduce((acc, p) => {
  acc[PATTERN_KEY[p.label]] = {
    label: p.label,
    meaning: p.meaning,
    bestNextMove: p.bestNextMove,
  };
  return acc;
}, {});

const COMB_TYPES = {
  Capability:  'How-to guide, walkthrough, or framework',
  Opportunity: 'Template, prompt pack, tool, or system',
  Motivation:  'Reflection, reframe, or short essay',
};

// ─────────────────────────────────────────────────────────────────
// SCORING ENGINE
// ─────────────────────────────────────────────────────────────────
function questionsBySubdomain(subId) {
  return QUESTIONS.filter(q => q.subdomain === subId);
}

function questionsByStage(stageId) {
  return QUESTIONS.filter(q => q.stage === stageId);
}

function calcSubdomainScore(answers, subId) {
  const qs = questionsBySubdomain(subId);
  const max = qs.reduce((s, q) => s + q.weight * 4, 0);
  const actual = qs.reduce((s, q) => s + (answers[q.id] || 0) * q.weight, 0);
  return max === 0 ? 0 : Math.round((actual / max) * 100);
}

function calcStageScore(answers, stageId) {
  const subs = SUBDOMAINS.filter(s => s.stage === stageId);
  const scores = subs.map(s => calcSubdomainScore(answers, s.id));
  return Math.round(scores.reduce((a, b) => a + b, 0) / scores.length);
}

function calcOverallScore(stageScores) {
  return Math.round(
    stageScores.download * STAGE_WEIGHT.download +
    stageScores.idea     * STAGE_WEIGHT.idea +
    stageScores.creation * STAGE_WEIGHT.creation
  );
}

function getBand(score) {
  if (score < 50) return { label: 'Foundation', desc: "You're building the foundations of a maker practice." };
  if (score < 65) return { label: 'Developing', desc: 'Your practice is taking shape; some areas working, others not yet.' };
  if (score < 80) return { label: 'Strong',     desc: 'Most of the moves are working; refinement is the next direction.' };
  return              { label: 'Advanced',   desc: 'Practice runs cleanly across all three stages.' };
}

function getPriority(score) {
  if (score < 50) return 'High';
  if (score < 70) return 'Medium';
  return 'Low';
}

// ─────────────────────────────────────────────────────────────────
// PATTERN DETECTION
// ─────────────────────────────────────────────────────────────────
function detectPatternKey(stageScores) {
  const entries = Object.entries(stageScores).sort((a, b) => b[1] - a[1]);
  const [hStage, H] = entries[0];
  const [, M]       = entries[1];
  const [lStage, L] = entries[2];

  // 1. Even Maker
  if (H - L <= 15) return 'even';

  // 2. Dominant-stage profiles
  if (H - M >= 12 && H - L >= 18) {
    if (hStage === 'download') return 'collector';
    if (hStage === 'idea')     return 'thinker';
    if (hStage === 'creation') return 'builder';
  }

  // 3. Low-stage bottleneck profiles
  if (L < 50 && (H + M) / 2 >= 60) {
    if (lStage === 'creation') return 'stuckUpstream';
    if (lStage === 'idea')     return 'stuckMidstream';
    if (lStage === 'download') return 'rushed';
  }

  // 4. Fallback
  return 'developing';
}

// ─────────────────────────────────────────────────────────────────
// SUBDOMAIN HELPERS
// ─────────────────────────────────────────────────────────────────
function getStrongestSubdomain(answers, stageId) {
  const subs = SUBDOMAINS.filter(s => s.stage === stageId);
  return subs.reduce((best, s) => calcSubdomainScore(answers, s.id) > calcSubdomainScore(answers, best.id) ? s : best);
}

function getWeakestSubdomain(answers, stageId) {
  const subs = SUBDOMAINS.filter(s => s.stage === stageId);
  return subs.reduce((worst, s) => calcSubdomainScore(answers, s.id) < calcSubdomainScore(answers, worst.id) ? s : worst);
}

// ─────────────────────────────────────────────────────────────────
// RESOURCE ROUTING
// ─────────────────────────────────────────────────────────────────
function getTopResources(answers, n = 5) {
  const items = QUESTIONS.map(q => {
    const r = answers[q.id] || 0;
    if (r === 0 || r > 2) return null;
    return { q, severity: (5 - r) * q.weight };
  }).filter(Boolean);

  items.sort((a, b) => b.severity - a.severity);
  return items.slice(0, n).map(i => i.q);
}

// ─────────────────────────────────────────────────────────────────
// STATE
// ─────────────────────────────────────────────────────────────────
const STORAGE_KEY = 'hideaway_memo_v1';

function loadState() {
  try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || { answers: {}, currentQ: 0 }; }
  catch { return { answers: {}, currentQ: 0 }; }
}

function saveState(s) {
  localStorage.setItem(STORAGE_KEY, JSON.stringify(s));
}

function clearState() {
  localStorage.removeItem(STORAGE_KEY);
}

let state = loadState();

// ─────────────────────────────────────────────────────────────────
// VIEWS
// ─────────────────────────────────────────────────────────────────
const VIEWS = ['intro', 'interstitial', 'questions', 'memo'];

function showView(name) {
  VIEWS.forEach(v => {
    const el = document.getElementById(`view-${v}`);
    if (el) el.style.display = v === name ? 'block' : 'none';
  });
  window.scrollTo(0, 0);
}

// ─────────────────────────────────────────────────────────────────
// QUESTION RENDERER
// ─────────────────────────────────────────────────────────────────
function getSubdomainObj(subId) {
  return SUBDOMAINS.find(s => s.id === subId);
}

function updateStageProgress(currentIndex) {
  const stageOrder = ['download', 'idea', 'creation'];
  stageOrder.forEach(stage => {
    const stageQs = questionsByStage(stage);
    const startIdx = QUESTIONS.findIndex(q => q.stage === stage);
    const endIdx = startIdx + stageQs.length - 1;
    const seg = document.getElementById(`q-seg-${stage}`);
    const fill = document.getElementById(`q-seg-fill-${stage}`);

    seg.classList.remove('seg-active', 'seg-done', 'seg-future');

    if (currentIndex > endIdx) {
      fill.style.width = '100%';
      seg.classList.add('seg-done');
    } else if (currentIndex >= startIdx) {
      const positionInStage = currentIndex - startIdx;
      const pct = (positionInStage / stageQs.length) * 100;
      fill.style.width = `${pct}%`;
      seg.classList.add('seg-active');
    } else {
      fill.style.width = '0%';
      seg.classList.add('seg-future');
    }
  });
}

function renderQuestion(index) {
  const q = QUESTIONS[index];
  if (!q) return;

  updateStageProgress(index);

  const sub = getSubdomainObj(q.subdomain);
  const stageQs = questionsByStage(q.stage);
  const stageQIndex = stageQs.findIndex(x => x.id === q.id) + 1;
  const stageLabel = STAGES.find(s => s.id === q.stage).label;

  document.getElementById('q-subdomain').textContent = sub.label;
  document.getElementById('q-subdomain-desc').textContent = sub.desc;
  document.getElementById('q-counter').textContent = `${stageLabel} · ${stageQIndex} of ${stageQs.length}`;
  document.getElementById('q-text').textContent = q.stem;

  const container = document.getElementById('q-options');
  const existing = state.answers[q.id];

  container.innerHTML = q.options.map((optText, i) => {
    const score = i + 1;
    const isSelected = existing === score;
    return `
      <label class="q-option${isSelected ? ' selected' : ''}">
        <input type="radio" name="q-response" value="${score}" ${isSelected ? 'checked' : ''} />
        <span class="q-option-label">${optText}</span>
      </label>
    `;
  }).join('');

  container.querySelectorAll('input[type="radio"]').forEach(radio => {
    radio.addEventListener('change', () => {
      state.answers[q.id] = parseInt(radio.value);
      saveState(state);
      container.querySelectorAll('.q-option').forEach(o => o.classList.remove('selected'));
      radio.closest('.q-option').classList.add('selected');
      document.getElementById('btn-next').disabled = false;
    });
  });

  document.getElementById('btn-next').disabled = !existing;
  document.getElementById('btn-back').style.visibility = index === 0 ? 'hidden' : 'visible';
}

// ─────────────────────────────────────────────────────────────────
// INTERSTITIAL RENDERER
// ─────────────────────────────────────────────────────────────────
const INTERSTITIALS = {
  idea: {
    badge: 'Download complete',
    heading: 'Next: Idea.',
    body: "You've mapped how you take material in. Next, we look at how you shape it into something specific.",
  },
  creation: {
    badge: 'Idea complete',
    heading: 'Next: Creation.',
    body: "You've mapped how you shape ideas. Next, we look at how you move from concept to actual output.",
  },
};

let pendingNextIndex = 0;

function showInterstitial(nextStage, nextIndex) {
  const data = INTERSTITIALS[nextStage];
  if (!data) return false;
  document.getElementById('int-badge').textContent = data.badge;
  document.getElementById('int-heading').textContent = data.heading;
  document.getElementById('int-body').textContent = data.body;
  pendingNextIndex = nextIndex;
  showView('interstitial');
  return true;
}

// ─────────────────────────────────────────────────────────────────
// MEMO RENDERER
// ─────────────────────────────────────────────────────────────────
function renderMemo() {
  const stageScores = {
    download: calcStageScore(state.answers, 'download'),
    idea:     calcStageScore(state.answers, 'idea'),
    creation: calcStageScore(state.answers, 'creation'),
  };
  const overall = calcOverallScore(stageScores);
  const band = getBand(overall);
  const patternKey = detectPatternKey(stageScores);
  const pattern = PATTERNS[patternKey];

  // Date
  document.getElementById('memo-date').textContent = new Date().toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' });

  // Overview
  document.getElementById('memo-overall-score').textContent = `${overall}%`;
  document.getElementById('memo-band').textContent = band.label;
  document.getElementById('memo-pattern-label').textContent = pattern.label;

  // Pattern
  document.getElementById('memo-pattern-meaning').textContent = pattern.meaning;
  document.getElementById('memo-pattern-next').textContent = pattern.bestNextMove;

  // Stage cards
  const stageGrid = document.getElementById('memo-stage-grid');
  stageGrid.innerHTML = STAGES.map(stage => {
    const score = stageScores[stage.id];
    const strongest = getStrongestSubdomain(state.answers, stage.id);
    const weakest = getWeakestSubdomain(state.answers, stage.id);
    return `
      <div class="memo-stage-card">
        <span class="memo-stage-name">${stage.label}.</span>
        <div class="memo-stage-score">${score}%</div>
        <div class="memo-stage-bar-track"><div class="memo-stage-bar-fill" style="width:${score}%"></div></div>
        <div class="memo-stage-meta">
          <div><strong>Strongest:</strong> ${strongest.label}</div>
          <div><strong>Weakest:</strong> ${weakest.label}</div>
        </div>
      </div>
    `;
  }).join('');

  // Subdomain table
  const subTable = document.getElementById('memo-sub-table');
  subTable.innerHTML = SUBDOMAINS.map(sub => {
    const score = calcSubdomainScore(state.answers, sub.id);
    const priority = getPriority(score);
    const stageLabel = STAGES.find(s => s.id === sub.stage).label;
    return `
      <div class="memo-sub-row">
        <span class="memo-sub-stage">${stageLabel}</span>
        <span class="memo-sub-name">${sub.label}</span>
        <span class="memo-sub-score">${score}%</span>
        <span class="memo-sub-priority priority-${priority}">${priority}</span>
      </div>
    `;
  }).join('');

  // Resources
  const resources = getTopResources(state.answers, 5);
  const resList = document.getElementById('memo-resource-list');
  if (resources.length === 0) {
    resList.innerHTML = `<p style="font-size: 0.92rem; color: rgba(26,39,68,0.6); margin: 0;">No urgent gaps surfaced. Browse the Library when you're ready to refine.</p>`;
  } else {
    resList.innerHTML = resources.map(q => {
      const sub = getSubdomainObj(q.subdomain);
      const stageLabel = STAGES.find(s => s.id === q.stage).label;
      return `
        <div class="memo-resource-card">
          <div>
            <span class="memo-resource-tag">${stageLabel} · ${sub.label}</span>
            <p class="memo-resource-stem">${q.stem}</p>
            <span class="memo-resource-type">${COMB_TYPES[q.comb]}</span>
          </div>
          <div class="memo-resource-meta">
            ${q.comb}<br>${q.resourceTag}
          </div>
        </div>
      `;
    }).join('');
  }
}

// ─────────────────────────────────────────────────────────────────
// EVENT WIRING
// ─────────────────────────────────────────────────────────────────
document.getElementById('btn-begin').addEventListener('click', () => {
  showView('questions');
  renderQuestion(state.currentQ);
});

document.getElementById('btn-next').addEventListener('click', () => {
  const currentQ = QUESTIONS[state.currentQ];
  const nextIndex = state.currentQ + 1;

  if (nextIndex >= QUESTIONS.length) {
    renderMemo();
    showView('memo');
    return;
  }

  const nextQ = QUESTIONS[nextIndex];
  if (nextQ.stage !== currentQ.stage) {
    showInterstitial(nextQ.stage, nextIndex);
  } else {
    state.currentQ = nextIndex;
    saveState(state);
    renderQuestion(nextIndex);
  }
});

document.getElementById('btn-back').addEventListener('click', () => {
  if (state.currentQ > 0) {
    state.currentQ -= 1;
    saveState(state);
    renderQuestion(state.currentQ);
  }
});

document.getElementById('btn-continue').addEventListener('click', () => {
  state.currentQ = pendingNextIndex;
  saveState(state);
  showView('questions');
  renderQuestion(pendingNextIndex);
});

function retake() {
  clearState();
  state = { answers: {}, currentQ: 0 };
  showView('intro');
}

document.getElementById('btn-retake-memo').addEventListener('click', retake);

// ─────────────────────────────────────────────────────────────────
// RESTORE
// ─────────────────────────────────────────────────────────────────
if (state.currentQ > 0 || Object.keys(state.answers).length > 0) {
  const allDone = Object.keys(state.answers).length === QUESTIONS.length;
  if (allDone) {
    renderMemo();
    showView('memo');
  } else {
    showView('questions');
    renderQuestion(state.currentQ);
  }
}
</script>
</BaseLayout>
