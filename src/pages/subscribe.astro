---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Subscribe | hideaway."
  description="New resources from Laura, straight to your inbox — when they're ready, not on a schedule."
>
  <div class="subscribe-page">
    <div class="subscribe-inner">

      <div class="subscribe-tag">Stay in the loop</div>
      <h1>Worth staying for.</h1>
      <p class="lead">
        New guides, prompts, demos, and honest reflections — when they're ready. No noise, no
        schedule, no content for content's sake.
      </p>
      <p>
        If you've found something useful at hideaway., this is the best way to get more of it.
        I write when I have something worth saying.
      </p>

      <form class="subscribe-form" name="email-signup" method="POST" data-netlify="true" action="/thank-you">
        <input type="hidden" name="form-name" value="email-signup" />
        <div class="subscribe-row">
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
            aria-label="Email address"
          />
          <button type="submit" class="btn-primary">Subscribe</button>
        </div>
        <p class="subscribe-note">Free. Unsubscribe whenever. No spam, ever.</p>
      </form>

      <div class="what-to-expect">
        <h2>What to expect</h2>
        <ul>
          <li>Practical guides on building with AI — not theory, actual builds</li>
          <li>Copy-and-use prompts that actually work</li>
          <li>Behind-the-scenes on Bothy. and Atlas. as they grow</li>
          <li>The occasional honest reflection on what's hard about all of this</li>
        </ul>
      </div>

    </div>
  </div>
</BaseLayout>

<style>
  .subscribe-page {
    padding-top: 8rem;
    padding-bottom: 6rem;
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .subscribe-inner {
    max-width: 580px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .subscribe-tag {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--sage);
    margin-bottom: 1rem;
  }

  .subscribe-inner h1 {
    font-family: 'Fraunces', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 400;
    color: var(--navy);
    margin-bottom: 1.2rem;
    letter-spacing: -0.01em;
  }

  .lead {
    font-size: 1.1rem;
    line-height: 1.75;
    color: var(--text);
    margin-bottom: 1rem;
  }

  .subscribe-inner > p:not(.lead) {
    font-size: 0.95rem;
    line-height: 1.75;
    color: var(--text-light);
    margin-bottom: 0;
  }

  .subscribe-form {
    margin: 2.5rem 0 0;
    background: white;
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 2rem;
  }

  .subscribe-row {
    display: flex;
    gap: 0.6rem;
  }

  .subscribe-row input[type="email"] {
    flex: 1;
    padding: 0.8rem 1rem;
    border: 1.5px solid var(--border);
    border-radius: 6px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    color: var(--navy);
    background: var(--frosted);
    outline: none;
    transition: border-color 0.25s;
  }

  .subscribe-row input[type="email"]:focus {
    border-color: var(--navy);
  }

  .subscribe-row input[type="email"]::placeholder {
    color: var(--text-light);
  }

  .subscribe-note {
    font-size: 0.78rem;
    color: var(--text-light);
    margin-top: 0.7rem;
  }

  .what-to-expect {
    margin-top: 3rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--border);
  }

  .what-to-expect h2 {
    font-family: 'Fraunces', serif;
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--navy);
    margin-bottom: 1rem;
  }

  .what-to-expect ul {
    list-style: none;
    padding: 0;
  }

  .what-to-expect li {
    font-size: 0.95rem;
    color: var(--text-light);
    line-height: 1.7;
    padding: 0.6rem 0 0.6rem 1.4rem;
    position: relative;
    border-bottom: 1px solid var(--border);
  }

  .what-to-expect li:last-child {
    border-bottom: none;
  }

  .what-to-expect li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--sage);
    font-size: 0.85rem;
  }

  @media (max-width: 600px) {
    .subscribe-inner {
      padding: 0 1.5rem;
    }

    .subscribe-page {
      padding-top: 6rem;
      align-items: flex-start;
    }

    .subscribe-row {
      flex-direction: column;
    }
  }
</style>
